{
  "version": 2,
  "buildCommand": "pnpm -w run vercel-build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/server.ts": {
      "maxDuration": 30
    }
  }
}
