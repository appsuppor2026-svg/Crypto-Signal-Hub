{
  "version": 2,
  "buildCommand": "PORT=3000 BASE_PATH=/ pnpm --filter @workspace/liquidity-radar run build",
  "outputDirectory": "artifacts/liquidity-radar/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "functions": {
    "api/server.ts": {
      "maxDuration": 30
    }
  }
}
